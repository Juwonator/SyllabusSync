# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/syllabussync

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_at_least_32_characters_long
JWT_AUDIENCE=syllabus-sync
JWT_ISSUER=syllabus-sync

# MFA Security Configuration
# Must be a 32-byte hex-encoded key (64 hexadecimal characters)
# Generate one using: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f
